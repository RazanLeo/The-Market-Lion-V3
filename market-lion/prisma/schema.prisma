// Prisma schema for The Market Lion (v3)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  OWNER
}

enum SubscriptionPlan {
  INDIVIDUAL_MONTHLY
  INSTITUTION_MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  emailVerified   DateTime?
  name            String?
  phone           String?
  country         String?
  city            String?
  timezone        String?
  passwordHash    String?
  role            Role     @default(USER)
  language        String   @default("ar")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tradingAccount  TradingAccount?
  subscription    Subscription?
  preferences     UserPreferences?
  trades          Trade[]
  reports         Report[]
  apiKeys         ApiKey[]
}

model TradingAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  broker       String   @default("Exness")
  accountType  String   @default("MT5")
  loginNumber  String
  serverName   String
  // Investor-only password is acceptable; trader password is encrypted at rest.
  passwordEnc  String
  capital      Decimal  @default(0)
  leverage     Int      @default(500)
  status       String   @default("PENDING") // PENDING|CONNECTED|FAILED
  lastSyncAt   DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String             @id @default(cuid())
  userId       String             @unique
  plan         SubscriptionPlan
  status       SubscriptionStatus @default(ACTIVE)
  startsAt     DateTime           @default(now())
  endsAt       DateTime
  amountSAR    Int
  paymentRef   String?
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  asset           String   @default("XAU/USD")
  riskPercent     Int      @default(2)
  timeframe       String   @default("15M")
  tradingMode     String   @default("BOT") // BOT|MANUAL
  language        String   @default("ar")
  // Color overrides (optional, hex)
  colorBg         String?
  colorGold       String?
  colorBuy        String?
  colorSell       String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trade {
  id           String   @id @default(cuid())
  userId       String
  asset        String
  side         String   // BUY|SELL
  lots         Decimal
  entryPrice   Decimal
  sl           Decimal
  tp1          Decimal
  tp2          Decimal
  tp3          Decimal
  tp4          Decimal
  status       String   @default("OPEN") // OPEN|CLOSED|CANCELLED
  pnl          Decimal  @default(0)
  openedAt     DateTime @default(now())
  closedAt     DateTime?
  source       String   @default("BOT")  // BOT|MANUAL
  confluence   Decimal  @default(0)
  notes        String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  kind        String   // DAILY|WEEKLY|MONTHLY
  periodStart DateTime
  periodEnd   DateTime
  pdfUrl      String?
  summary     Json
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  name      String
  keyHash   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  meta      Json
  createdAt DateTime @default(now())
}

// NextAuth required tables (if using Adapter)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}
