# === Application ===
NEXT_PUBLIC_APP_NAME="The Market Lion"
NEXT_PUBLIC_APP_NAME_AR="أسد السوق"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# === Database (Postgres in production, SQLite locally) ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marketlion?schema=public"

# === NextAuth ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_string

# === Trading account (per-user; admin can override) ===
# These are placeholders ONLY. Each user supplies their own credentials at signup.
EXNESS_DEFAULT_SERVER="Exness-MT5Trial15"

# === Free / open data sources (no paid APIs by default) ===
YAHOO_FINANCE_BASE=https://query1.finance.yahoo.com
FRED_BASE=https://api.stlouisfed.org/fred
NEWS_RSS_REUTERS=https://feeds.reuters.com/reuters/businessNews
NEWS_RSS_BLOOMBERG=https://feeds.bloomberg.com/markets/news.rss
NEWS_RSS_CNBC=https://www.cnbc.com/id/100003114/device/rss/rss.html

# === Optional: Crypto/FX backups ===
COINGECKO_BASE=https://api.coingecko.com/api/v3
